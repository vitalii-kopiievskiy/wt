mixin  products-add (compareId, wishId)
    ul.products-add
        li.products-add__item
            .products-add__btn.products-buy-link(data-id= compareId)
                img.products-add__icon(src="./assets/img/products/basket_icon.svg", alt="basket icon")
                span.products-add__text Купить товар
        li.products-add__item
            .products-add__btn.products-wishlist(data-id= wishId)
                img.products-add__icon(src="./assets/img/products/wishlist_icon.svg", alt="wishlist icon")
                span.products-add__text В избранное
