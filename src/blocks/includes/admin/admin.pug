section.admin-panel#adminPanel
  .admin-panel__head
    .admin-panel__title-block
      h1.admin-panel__title Админка
      p.admin-panel__subtitle Управление товарами, заказами и пользователями
    a.admin-panel__back(href="index.html") В каталог

  .admin-panel__notice#adminNotice Проверяем права доступа...

  .admin-panel__workspace#adminWorkspace(hidden)
    .admin-panel__tabs(role="tablist")
      button.admin-panel__tab.is-active(type="button" data-admin-tab="products") Товары
      button.admin-panel__tab(type="button" data-admin-tab="orders") Заказы
      button.admin-panel__tab(type="button" data-admin-tab="users") Пользователи

    .admin-panel__section.is-active(data-admin-panel="products")
      .admin-panel__section-head
        h2.admin-panel__section-title Товары
        button.admin-panel__secondary-btn#refreshProductsBtn(type="button") Обновить
      .admin-panel__grid
        form.admin-form#adminProductForm
          input(type="hidden" name="id")
          .admin-form__row
            label.admin-form__field
              span Название
              input(type="text" name="name" required)
            label.admin-form__field
              span Slug
              input(type="text" name="slug" required)
          label.admin-form__field
            span Описание
            textarea(name="description" rows="4")
          .admin-form__row
            label.admin-form__field
              span Цена
              input(type="number" name="price" min="0" step="0.01" required)
            label.admin-form__field
              span Старая цена
              input(type="number" name="old_price" min="0" step="0.01")
          .admin-form__row
            label.admin-form__field
              span Бренд
              input(type="text" name="brand")
            label.admin-form__field
              span Категория
              input(type="text" name="category")
          .admin-form__row
            label.admin-form__field
              span Остаток
              input(type="number" name="stock_quantity" min="0" step="1" value="0")
            label.admin-form__field
              span URL изображения
              input(type="text" name="image_url")
          label.admin-form__checkbox
            input(type="checkbox" name="is_active" checked)
            span Активный товар
          .admin-form__actions
            button.admin-panel__primary-btn(type="submit") Сохранить
            button.admin-panel__secondary-btn#resetProductFormBtn(type="button") Новый товар
        .admin-table-wrap
          table.admin-table
            thead
              tr
                th ID
                th Товар
                th Цена
                th Остаток
                th Статус
                th Действия
            tbody#adminProductsTable

    .admin-panel__section(data-admin-panel="orders")
      .admin-panel__section-head
        h2.admin-panel__section-title Заказы
        button.admin-panel__secondary-btn#refreshOrdersAdminBtn(type="button") Обновить
      .admin-panel__grid
        .admin-table-wrap
          table.admin-table
            thead
              tr
                th ID
                th User
                th Статус
                th Сумма
                th Создан
                th Действия
            tbody#adminOrdersTable
        .admin-panel__details#adminOrderDetails
          p.admin-panel__empty Выберите заказ

    .admin-panel__section(data-admin-panel="users")
      .admin-panel__section-head
        h2.admin-panel__section-title Пользователи
        button.admin-panel__secondary-btn#refreshUsersBtn(type="button") Обновить
      .admin-table-wrap
        table.admin-table
          thead
            tr
              th ID
              th Email
              th Имя
              th Роль
              th Активен
              th Создан
          tbody#adminUsersTable
