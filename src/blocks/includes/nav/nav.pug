nav#nav
    .container
        .nav
            include burger/burger
            ul.nav__list#navList
                each txt, i in ['Главная', 'О компании', 'Ссылка 1', 'Ссылка 2', 'Ссылка 3']
                    if i == 0
                        li.nav__item
                            a(href="#").nav__link.nav__link--active.prevent-link= txt
                    else
                        li.nav__item
                            a(href="#").nav__link.prevent-link= txt
                li.nav__item.nav__item--admin#adminNavItem
                    a(href="admin.html").nav__link Админка
            include __button/nav__button.pug
        include -modal/nav-modal
        include -account/account-modal
